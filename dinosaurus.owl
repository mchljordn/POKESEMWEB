@prefix : <http://example.org/dino#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://example.org/dino> .

<http://example.org/dino> rdf:type owl:Ontology .

### =======================================
### KELAS (CLASSES)
### =======================================
:Dinosaur rdf:type owl:Class .
:Diet rdf:type owl:Class .
:Era rdf:type owl:Class .
:Region rdf:type owl:Class .
:Clade rdf:type owl:Class .
:Locomotion rdf:type owl:Class .

### =======================================
### RELASI (OBJECT PROPERTIES)
### =======================================
:hasDiet rdf:type owl:ObjectProperty ; rdfs:domain :Dinosaur ; rdfs:range :Diet .
:livedIn rdf:type owl:ObjectProperty ; rdfs:domain :Dinosaur ; rdfs:range :Era .
:discoveredIn rdf:type owl:ObjectProperty ; rdfs:domain :Dinosaur ; rdfs:range :Region .
:belongsToClade rdf:type owl:ObjectProperty ; rdfs:domain :Dinosaur ; rdfs:range :Clade .
:movementType rdf:type owl:ObjectProperty ; rdfs:domain :Dinosaur ; rdfs:range :Locomotion .

### =======================================
### ATRIBUT (DATA PROPERTIES)
### =======================================
:name rdf:type owl:DatatypeProperty ; rdfs:domain :Dinosaur ; rdfs:range xsd:string .
:meaningOfName rdf:type owl:DatatypeProperty ; rdfs:domain :Dinosaur ; rdfs:range xsd:string .
:length rdf:type owl:DatatypeProperty ; rdfs:domain :Dinosaur ; rdfs:range xsd:decimal .
:weightTons rdf:type owl:DatatypeProperty ; rdfs:domain :Dinosaur ; rdfs:range xsd:decimal .
:description rdf:type owl:DatatypeProperty ; rdfs:domain :Dinosaur ; rdfs:range xsd:string .
:image rdf:type owl:DatatypeProperty ; rdfs:domain :Dinosaur ; rdfs:range xsd:string .

### =======================================
### DATA KATEGORI (INDIVIDUALS)
### =======================================
:Carnivore rdf:type owl:NamedIndividual , :Diet ; rdfs:label "Karnivora" .
:Herbivore rdf:type owl:NamedIndividual , :Diet ; rdfs:label "Herbivora" .
:Cretaceous rdf:type owl:NamedIndividual , :Era ; rdfs:label "Cretaceous" .
:Jurassic rdf:type owl:NamedIndividual , :Era ; rdfs:label "Jurassic" .
:NorthAmerica rdf:type owl:NamedIndividual , :Region ; rdfs:label "Amerika Utara" .
:Asia rdf:type owl:NamedIndividual , :Region ; rdfs:label "Asia" .
:Theropod rdf:type owl:NamedIndividual , :Clade ; rdfs:label "Theropoda" .
:Ceratopsian rdf:type owl:NamedIndividual , :Clade ; rdfs:label "Ceratopsia" .
:Bipedal rdf:type owl:NamedIndividual , :Locomotion ; rdfs:label "Bipedal (2 Kaki)" .
:Quadrupedal rdf:type owl:NamedIndividual , :Locomotion ; rdfs:label "Quadrupedal (4 Kaki)" .

### =======================================
### DATA DINOSAURUS (INDIVIDUALS)
### =======================================
:TRex rdf:type owl:NamedIndividual , :Dinosaur ;
      :name "Tyrannosaurus Rex" ;
      :meaningOfName "Raja Kadal Tiran" ;
      :length 12.3 ;
      :weightTons 8.4 ;
      :description "Predator puncak seukuran bus sekolah dengan gigitan terkuat di antara hewan darat." ;
      :image "https://upload.wikimedia.org/wikipedia/commons/thumb/f/f6/Tyrannosaurus_rex_mmartyniuk.png/320px-Tyrannosaurus_rex_mmartyniuk.png" ;
      :hasDiet :Carnivore ;
      :livedIn :Cretaceous ;
      :discoveredIn :NorthAmerica ;
      :belongsToClade :Theropod ;
      :movementType :Bipedal .

:Triceratops rdf:type owl:NamedIndividual , :Dinosaur ;
      :name "Triceratops" ;
      :meaningOfName "Wajah Bertanduk Tiga" ;
      :length 9.0 ;
      :weightTons 6.0 ;
      :description "Herbivora bertubuh kekar mirip badak dengan tiga tanduk dan perisai kepala kokoh." ;
      :image "https://upload.wikimedia.org/wikipedia/commons/thumb/e/e3/Triceratops_dorsalis.jpg/320px-Triceratops_dorsalis.jpg" ;
      :hasDiet :Herbivore ;
      :livedIn :Cretaceous ;
      :discoveredIn :NorthAmerica ;
      :belongsToClade :Ceratopsian ;
      :movementType :Quadrupedal .