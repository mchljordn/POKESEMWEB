<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:poke="http://example.org/pokemon/">

  <rdf:Description rdf:about="http://example.org/pokemon/">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <rdfs:label>Pokemon Ontology</rdfs:label>
    <rdfs:comment>Ontology untuk mendeskripsikan data Pokémon dengan semantic web</rdfs:comment>
  </rdf:Description>

  <!-- =============================================== -->
  <!-- TOP-LEVEL CLASSES -->
  <!-- =============================================== -->
  
  <rdf:Description rdf:about="http://example.org/pokemon/Pokemon">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Pokemon</rdfs:label>
    <rdfs:comment>Kelas utama yang merepresentasikan seekor Pokémon</rdfs:comment>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/StarterPokemon">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Starter Pokemon</rdfs:label>
    <rdfs:comment>Pokémon pemula yang bisa dipilih di awal game</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/pokemon/Pokemon"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/LegendaryPokemon">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Legendary Pokemon</rdfs:label>
    <rdfs:comment>Pokémon legendaris yang sangat langka</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/pokemon/Pokemon"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/MythicalPokemon">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Mythical Pokemon</rdfs:label>
    <rdfs:comment>Pokémon mistis yang hanya tersedia melalui event khusus</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/pokemon/LegendaryPokemon"/>
  </rdf:Description>

  <!-- =============================================== -->
  <!-- MASTER DATA CLASSES -->
  <!-- =============================================== -->
  
  <rdf:Description rdf:about="http://example.org/pokemon/Type">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Type</rdfs:label>
    <rdfs:comment>Tipe Pokémon (Grass, Fire, Water, Electric, Normal, Poison, Flying, dll)</rdfs:comment>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/Ability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Ability</rdfs:label>
    <rdfs:comment>Kemampuan atau skill yang dimiliki Pokémon</rdfs:comment>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/Generation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Generation</rdfs:label>
    <rdfs:comment>Generasi atau rilis Pokémon (Gen 1-9)</rdfs:comment>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/Region">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Region</rdfs:label>
    <rdfs:comment>Region atau area geografis dalam Pokemon (Kanto, Johto, Hoenn, dll)</rdfs:comment>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/Move">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Move</rdfs:label>
    <rdfs:comment>Serangan atau gerakan yang bisa dilakukan Pokémon</rdfs:comment>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/Item">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Item</rdfs:label>
    <rdfs:comment>Item atau benda yang dapat digunakan dalam game</rdfs:comment>
  </rdf:Description>

  <!-- =============================================== -->
  <!-- POKEMON PROPERTIES (Data Properties) -->
  <!-- =============================================== -->

  <rdf:Description rdf:about="http://example.org/pokemon/name">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>name</rdfs:label>
    <rdfs:comment>Nama Pokémon</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Pokemon"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/pokedexNumber">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>pokedexNumber</rdfs:label>
    <rdfs:comment>Nomor urut di Pokedex</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Pokemon"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/heightM">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>heightM</rdfs:label>
    <rdfs:comment>Tinggi Pokémon dalam meter</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Pokemon"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/weightKg">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>weightKg</rdfs:label>
    <rdfs:comment>Berat Pokémon dalam kilogram</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Pokemon"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/captureRate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>captureRate</rdfs:label>
    <rdfs:comment>Tingkat kesulitan menangkap Pokémon (0-255)</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Pokemon"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>

  <!-- =============================================== -->
  <!-- BASE STATS PROPERTIES -->
  <!-- =============================================== -->

  <rdf:Description rdf:about="http://example.org/pokemon/baseHP">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>baseHP</rdfs:label>
    <rdfs:comment>Statistik dasar HP (Health Points)</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Pokemon"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/baseAttack">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>baseAttack</rdfs:label>
    <rdfs:comment>Statistik dasar Attack (Serangan Fisik)</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Pokemon"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/baseDefense">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>baseDefense</rdfs:label>
    <rdfs:comment>Statistik dasar Defense (Pertahanan Fisik)</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Pokemon"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/baseSpAttack">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>baseSpAttack</rdfs:label>
    <rdfs:comment>Statistik dasar Special Attack (Serangan Spesial)</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Pokemon"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/baseSpDefense">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>baseSpDefense</rdfs:label>
    <rdfs:comment>Statistik dasar Special Defense (Pertahanan Spesial)</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Pokemon"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/baseSpeed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>baseSpeed</rdfs:label>
    <rdfs:comment>Statistik dasar Speed (Kecepatan)</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Pokemon"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/baseStatTotal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>baseStatTotal</rdfs:label>
    <rdfs:comment>Total keseluruhan statistik dasar</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Pokemon"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>

  <!-- =============================================== -->
  <!-- IMAGE & MEDIA PROPERTIES -->
  <!-- =============================================== -->

  <rdf:Description rdf:about="http://example.org/pokemon/imageUrl">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>imageUrl</rdfs:label>
    <rdfs:comment>URL ke gambar official artwork Pokémon</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Pokemon"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
  </rdf:Description>

  <!-- =============================================== -->
  <!-- OBJECT PROPERTIES (Relationships) -->
  <!-- =============================================== -->

  <rdf:Description rdf:about="http://example.org/pokemon/hasPrimaryType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>hasPrimaryType</rdfs:label>
    <rdfs:comment>Tipe utama Pokémon</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Pokemon"/>
    <rdfs:range rdf:resource="http://example.org/pokemon/Type"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/hasSecondaryType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>hasSecondaryType</rdfs:label>
    <rdfs:comment>Tipe sekunder Pokémon (jika ada)</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Pokemon"/>
    <rdfs:range rdf:resource="http://example.org/pokemon/Type"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/hasAbility">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>hasAbility</rdfs:label>
    <rdfs:comment>Kemampuan normal yang dimiliki Pokémon</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Pokemon"/>
    <rdfs:range rdf:resource="http://example.org/pokemon/Ability"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/hasHiddenAbility">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>hasHiddenAbility</rdfs:label>
    <rdfs:comment>Kemampuan tersembunyi (hidden ability) Pokémon</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Pokemon"/>
    <rdfs:range rdf:resource="http://example.org/pokemon/Ability"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/belongsToGen">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>belongsToGen</rdfs:label>
    <rdfs:comment>Generasi tempat Pokémon pertama kali dikenalkan</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Pokemon"/>
    <rdfs:range rdf:resource="http://example.org/pokemon/Generation"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/discoveredIn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>discoveredIn</rdfs:label>
    <rdfs:comment>Region tempat Pokémon pertama kali ditemukan</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Pokemon"/>
    <rdfs:range rdf:resource="http://example.org/pokemon/Region"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/evolvesInto">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>evolvesInto</rdfs:label>
    <rdfs:comment>Pokémon yang menjadi evolusi dari Pokémon ini</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Pokemon"/>
    <rdfs:range rdf:resource="http://example.org/pokemon/Pokemon"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/evolvesFrom">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>evolvesFrom</rdfs:label>
    <rdfs:comment>Pokémon yang berkembang menjadi Pokémon ini</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Pokemon"/>
    <rdfs:range rdf:resource="http://example.org/pokemon/Pokemon"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/canLearnMove">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>canLearnMove</rdfs:label>
    <rdfs:comment>Gerakan/serangan yang dapat dipelajari Pokémon</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Pokemon"/>
    <rdfs:range rdf:resource="http://example.org/pokemon/Move"/>
  </rdf:Description>

  <!-- =============================================== -->
  <!-- EVOLUTION PROPERTIES -->
  <!-- =============================================== -->

  <rdf:Description rdf:about="http://example.org/pokemon/evolutionMethod">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>evolutionMethod</rdfs:label>
    <rdfs:comment>Metode evolusi (level-up, stone, trade, friendship, dll)</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Pokemon"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/evolutionLevel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>evolutionLevel</rdfs:label>
    <rdfs:comment>Level yang diperlukan untuk evolusi (jika method adalah level-up)</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Pokemon"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>

  <!-- =============================================== -->
  <!-- GENERATION PROPERTIES -->
  <!-- =============================================== -->

  <rdf:Description rdf:about="http://example.org/pokemon/genNumber">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>genNumber</rdfs:label>
    <rdfs:comment>Nomor generasi (1-9)</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Generation"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/genYearReleased">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>genYearReleased</rdfs:label>
    <rdfs:comment>Tahun rilis generasi Pokémon</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Generation"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
  </rdf:Description>

  <!-- =============================================== -->
  <!-- REGION PROPERTIES -->
  <!-- =============================================== -->

  <rdf:Description rdf:about="http://example.org/pokemon/regionName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>regionName</rdfs:label>
    <rdfs:comment>Nama region dalam game Pokémon</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Region"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/regionBasedOn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>regionBasedOn</rdfs:label>
    <rdfs:comment>Lokasi geografis nyata yang menjadi inspirasi region</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Region"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/regionIntroducedIn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>regionIntroducedIn</rdfs:label>
    <rdfs:comment>Generasi dimana region dikenalkan</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Region"/>
    <rdfs:range rdf:resource="http://example.org/pokemon/Generation"/>
  </rdf:Description>

  <!-- =============================================== -->
  <!-- TYPE PROPERTIES -->
  <!-- =============================================== -->

  <rdf:Description rdf:about="http://example.org/pokemon/typeEffectiveAgainst">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>typeEffectiveAgainst</rdfs:label>
    <rdfs:comment>Tipe yang efektif terhadap tipe ini (super effective)</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Type"/>
    <rdfs:range rdf:resource="http://example.org/pokemon/Type"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/typeWeakAgainst">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>typeWeakAgainst</rdfs:label>
    <rdfs:comment>Tipe yang rentan terhadap tipe ini</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Type"/>
    <rdfs:range rdf:resource="http://example.org/pokemon/Type"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/typeResistant">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>typeResistant</rdfs:label>
    <rdfs:comment>Tipe yang kebal atau tahan terhadap tipe ini</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Type"/>
    <rdfs:range rdf:resource="http://example.org/pokemon/Type"/>
  </rdf:Description>

  <!-- =============================================== -->
  <!-- ABILITY PROPERTIES -->
  <!-- =============================================== -->

  <rdf:Description rdf:about="http://example.org/pokemon/abilityDescription">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>abilityDescription</rdfs:label>
    <rdfs:comment>Deskripsi efek kemampuan Pokémon</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Ability"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/isHidden">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>isHidden</rdfs:label>
    <rdfs:comment>Apakah ini hidden ability (hanya tersedia di Pokemon tertentu)</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Ability"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </rdf:Description>

  <!-- =============================================== -->
  <!-- MOVE PROPERTIES -->
  <!-- =============================================== -->

  <rdf:Description rdf:about="http://example.org/pokemon/moveName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>moveName</rdfs:label>
    <rdfs:comment>Nama gerakan/serangan</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Move"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/movePower">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>movePower</rdfs:label>
    <rdfs:comment>Kekuatan/power gerakan (0 untuk gerakan non-damage)</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Move"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/moveAccuracy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>moveAccuracy</rdfs:label>
    <rdfs:comment>Akurasi gerakan dalam persen (100 = selalu akurat)</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Move"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/moveType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>moveType</rdfs:label>
    <rdfs:comment>Tipe gerakan</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Move"/>
    <rdfs:range rdf:resource="http://example.org/pokemon/Type"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://example.org/pokemon/movePP">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>movePP</rdfs:label>
    <rdfs:comment>Power Points (jumlah kali gerakan bisa digunakan)</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/pokemon/Move"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>

  <!-- =============================================== -->
  <!-- CONSTRAINTS & RESTRICTIONS -->
  <!-- =============================================== -->

  <!-- Pokedex Number harus unik dan integer positif -->
  <rdf:Description rdf:about="http://example.org/pokemon/pokedexNumberRestriction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:comment>Pokedex number harus bernilai 1-1025 dan unik</rdfs:comment>
  </rdf:Description>

  <!-- Height dan Weight harus positif -->
  <rdf:Description rdf:about="http://example.org/pokemon/positiveNumericRestriction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:comment>Dimensi dan berat harus nilai positif</rdfs:comment>
  </rdf:Description>

  <!-- Base Stats harus 0-255 -->
  <rdf:Description rdf:about="http://example.org/pokemon/baseStatRestriction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:comment>Base stats harus bernilai 0-255</rdfs:comment>
  </rdf:Description>

  <!-- Capture Rate harus 0-255 -->
  <rdf:Description rdf:about="http://example.org/pokemon/captureRateRestriction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:comment>Capture rate harus bernilai 0-255</rdfs:comment>
  </rdf:Description>

  <!-- Generation harus 1-9 -->
  <rdf:Description rdf:about="http://example.org/pokemon/genNumberRestriction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:comment>Generation number harus 1-9</rdfs:comment>
  </rdf:Description>

</rdf:RDF>
